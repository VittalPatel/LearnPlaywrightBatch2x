{
  "info": {
    "name": "HMS API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@hms.local\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "List Patients",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/patients"
      }
    }
  ]
}
